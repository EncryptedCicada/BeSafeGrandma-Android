<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        The Activity window background colour before Compose paints its first frame.
        Using a neutral surface colour avoids the white flash on dark-mode devices.
    -->
    <style name="Theme.BeSafeGrandma" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>
</resources>